# ─── Backend Environment Variables (.env.example) ────────────────────────────
# Copy this file to .env and fill in the values

# AI API Key (Groq)
GROQ_API_KEY=your_groq_api_key_here

# Database
MONGODB_URL=mongodb://localhost:27017
# PRODUCTION (MongoDB Atlas):
# MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/cortexcraft

# Frontend URL for CORS
# LOCAL:
FRONTEND_URL=http://localhost:5173
# PRODUCTION (Vercel):
# FRONTEND_URL=https://your-project-name.vercel.app

# Backend base URL (used for file attachment links in Community etc.)
# LOCAL:
BASE_URL=http://127.0.0.1:8000
# PRODUCTION (Render):
# BASE_URL=https://your-backend-name.onrender.com
